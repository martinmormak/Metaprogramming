public class $entity.DaoName implements EntityDAO<$entity.Name> {
    private Connection connection;
    private DAOPersistenceManager daoPersistenceManager;

    public ${entity.DaoName}(DAOPersistenceManager daoPersistenceManager) {
        this.connection = daoPersistenceManager.getConnection();
        this.daoPersistenceManager = daoPersistenceManager;
    }

    @Override
    public void createTable() {
        try {
            PreparedStatement preparedStatement = connection.prepareStatement(
                    "${entity.CreateQuery}");
            preparedStatement.execute();
        } catch (SQLException e) {
            throw new PersistenceException("Cannot create $entity.Name");
        }
    }

    @Override
    public Optional<$entity.Name> get(long id) {
        try {
            PreparedStatement preparedStatement = connection.prepareStatement(
                    "${entity.SelectOneQuery}");
            preparedStatement.setLong(1, id);
            try (ResultSet resultSet = preparedStatement.executeQuery()) {
                if (resultSet.next()) {
                    return Optional.of(getInstanceFromDatabase(resultSet));
                }
            }
        } catch (SQLException e) {
            throw new PersistenceException("Cannot Select One $entity.Name");
        }
        return Optional.empty();
    }

    @Override
    public List<$entity.Name> getAll() {
        List<$entity.Name> instances = new ArrayList<>();
        try {
            PreparedStatement preparedStatement = connection.prepareStatement(
                    "${entity.SelectAllQuery}");
            try (ResultSet resultSet = preparedStatement.executeQuery()) {
                while (resultSet.next()) {
                    instances.add(getInstanceFromDatabase(resultSet));
                }
            }
        } catch (SQLException e) {
            throw new PersistenceException("Cannot Select One $entity.Name");
        }
        return instances;
    }

    @Override
    public void save(Object entity) {
        $entity.Name realObject = null;
        if (Proxy.isProxyClass(entity.getClass())) {
            System.out.println("entity was proxy");
            InvocationHandler handler = Proxy.getInvocationHandler(entity);

            if (handler instanceof LazyProxyHandler lazyHandler) {
                System.out.println("proxy is LazyProxyHandler");
                if (!lazyHandler.isInitialized()) {
                    System.out.println("proxy is unitialized");
                    return;
                }
                System.out.println("proxy is itialized");
                realObject = ($entity.Name) lazyHandler.getRealObject();
            }
        }
        if(realObject == null) {
            realObject = ($entity.Name) entity;
        }
        Object PK = realObject.${entity.IdColumn.GetterName}();

        try {
            if (!checkForeignKeysExists(realObject)) {
                throw new PersistenceException("Foreign keys doesn't exists");
            }
            if (PKExist("${entity.Name}", "${entity.PrimaryKey}", PK)) {
                try (PreparedStatement preparedStatement = connection.prepareStatement("${entity.UpdateQuery}")) {
                    #set($i = 1)
                    #foreach ($column in $entity.DatabaseColumnsList)
                        #set($shortType = $column.Type)
                        #set($columnName = $column.Name)
                        #set($methodSuffix = $columnName.substring(0, 1).toUpperCase() + $columnName.substring(1))
                        #if ($columnName != $entity.IdColumn.Name)  ## Skip the ID column
                            #if ($shortType == "class java.lang.String" || $shortType == "String")
                    preparedStatement.setString($i, realObject.get${methodSuffix}());
                            #elseif ($shortType == "class java.lang.Long" || $shortType == "long")
                    preparedStatement.setLong($i, realObject.get${methodSuffix}());
                            #elseif ($shortType == "class java.lang.Integer" || $shortType == "int")
                    preparedStatement.setInt($i, realObject.get${methodSuffix}());
                            #elseif ($shortType == "class java.lang.Float" || $shortType == "float")
                    preparedStatement.setFloat($i, realObject.get${methodSuffix}());
                            #elseif ($shortType == "class java.lang.Double" || $shortType == "double")
                    preparedStatement.setDouble($i, realObject.get${methodSuffix}());
                            #elseif ($shortType == "class java.lang.Boolean" || $shortType == "boolean")
                    preparedStatement.setBoolean($i, realObject.get${methodSuffix}());
                            #else
                                #foreach($fk in $entity.ForeignKeyList)
                                    #if($fk.SQLAlias.contains($columnName) || $fk.JavaName.contains($columnName))
                    Long id = null;
                    if (Proxy.isProxyClass(entity.getClass())) {
                        InvocationHandler handler = Proxy.getInvocationHandler(entity);

                        if (handler instanceof LazyProxyHandler<?>) {
                            LazyProxyHandler lazyHandler = (LazyProxyHandler) handler;
                            if (!lazyHandler.isInitialized()) {
                                //return -1;
                                throw new PersistenceException("Proxu is not initialized " + entity);
                            }

                            id = lazyHandler.getId();
                        }
                    }

                    if (id == null) {
                        id = (realObject.${fk.FieldGetterName}() != null && realObject.${fk.FieldGetterName}() instanceof ${fk.TargetClass}) ? ((${fk.TargetClass}) realObject.${fk.FieldGetterName}()).${fk.PKGetterName}() : null;
                    }

                    if (id != null) {
                        preparedStatement.setLong($i, id);
                    } else {
                        preparedStatement.setNull($i, java.sql.Types.BIGINT);
                    }
                                    #else
                    preparedStatement.setObject($i, realObject.get${methodSuffix}());
                                    #end
                                #end
                            #end
                            #set($i = $i + 1)
                        #end
                    #end
                    preparedStatement.setLong($i, realObject.${entity.IdColumn.GetterName}());

                    preparedStatement.executeUpdate();
                }
            } else {
                try (PreparedStatement preparedStatement = connection.prepareStatement("${entity.InsertQuery}", Statement.RETURN_GENERATED_KEYS)) {
                    #set($i = 1)
                    #foreach ($column in $entity.DatabaseColumnsList)
                        #set($shortType = $column.Type)
                        #set($columnName = $column.Name)
                        #set($methodSuffix = $columnName.substring(0, 1).toUpperCase() + $columnName.substring(1))
                        #if ($columnName != $entity.IdColumn.Name)  ## Skip the ID column
                            #if ($shortType == "class java.lang.String" || $shortType == "String")
                    preparedStatement.setString($i, realObject.get${methodSuffix}());
                            #elseif ($shortType == "class java.lang.Long" || $shortType == "long")
                    preparedStatement.setLong($i, realObject.get${methodSuffix}());
                            #elseif ($shortType == "class java.lang.Integer" || $shortType == "int")
                    preparedStatement.setInt($i, realObject.get${methodSuffix}());
                            #elseif ($shortType == "class java.lang.Double" || $shortType == "double")
                    preparedStatement.setDouble($i, realObject.get${methodSuffix}());
                            #elseif ($shortType == "class java.lang.Boolean" || $shortType == "boolean")
                    preparedStatement.setBoolean($i, realObject.get${methodSuffix}());
                            #else
                                #foreach($fk in $entity.ForeignKeyList)
                                    #if($fk.SQLAlias.contains($columnName) || $fk.JavaName.contains($columnName))
                    long id = -1;
                    if (Proxy.isProxyClass(entity.getClass())) {
                        InvocationHandler handler = Proxy.getInvocationHandler(entity);

                        if (handler instanceof LazyProxyHandler<?>) {
                            LazyProxyHandler lazyHandler = (LazyProxyHandler) handler;
                            if (!lazyHandler.isInitialized()) {
                                //return -1;
                                throw new PersistenceException("Proxu is not initialized " + entity);
                            }

                            id = lazyHandler.getId();
                        }
                    }

                    if (id == -1) {
                        id = (realObject.${fk.FieldGetterName}() != null && realObject.${fk.FieldGetterName}() instanceof ${fk.TargetClass}) ? ((${fk.TargetClass}) realObject.${fk.FieldGetterName}()).${fk.PKGetterName}() : null;
                    }

                    preparedStatement.setLong($i, id);
                                    #else
                    preparedStatement.setObject($i, realObject.get${methodSuffix}());
                                    #end
                                #end
                            #end
                            #set($i = $i + 1)
                        #end
                    #end
                    ResultSet resultSet = preparedStatement.executeQuery();
                    if (resultSet.next()) {
                        realObject.${entity.IdColumn.SetterName}(resultSet.getLong(1));
                    }
                }
            }
        } catch (SQLException e) {
            throw new PersistenceException("ID field not found for entity " + entity, e);
        }
    }

    @Override
    public void delete(Object obj) {
        $entity.Name entity = ($entity.Name) obj;
        Object PK = null;

        if (Proxy.isProxyClass(entity.getClass())) {
            System.out.println("entity was proxy");
            InvocationHandler handler = Proxy.getInvocationHandler(entity);

            if (handler instanceof LazyProxyHandler lazyHandler) {
                System.out.println("proxy is LazyProxyHandler");
                PK = lazyHandler.getId();
            }
        }

        if (PK == null) {
            PK = entity.${entity.IdColumn.GetterName}();
        }

        try (PreparedStatement preparedStatement = connection.prepareStatement("$entity.DeleteQuery")) {
            preparedStatement.setObject(1, PK);
            preparedStatement.execute();
        } catch (SQLException e) {
            throw new PersistenceException("Error deleting $entity.Name", e);
        }
    }

    private $entity.Name getInstanceFromDatabase(ResultSet resultSet) {
        try {
            // Create an instance of the entity class
            $entity.Name instance = new ${entity.Name}();
            // Dynamically iterate over the entity columns
            #foreach ($column in $entity.DatabaseColumnsList)
                #set($shortType = $column.Type)
                #set($columnName = $column.Name)
                #set($SQLAlias = $column.SQLAlias)
                #set($methodSuffix = $columnName.substring(0, 1).toUpperCase() + $columnName.substring(1))
                #set($lazyFetch = $column.LazyFetch)
                #set($isForeignKey = false)
                #foreach($fk in $entity.ForeignKeyList)
                    #if($fk.SQLAlias.contains($columnName) || $fk.JavaName.contains($columnName))
                        #set($isForeignKey = true)
                        #break
                    #end
                #end
                #if ($shortType == "class java.lang.String" || $shortType == "String")
            instance.set${methodSuffix}(resultSet.getString("$SQLAlias"));
                #elseif ($shortType == "class java.lang.Long" || $shortType == "long")
            instance.set${methodSuffix}(resultSet.getLong("$SQLAlias"));
                #elseif ($shortType == "class java.lang.Integer" || $shortType == "int")
            instance.set${methodSuffix}(resultSet.getInt("$SQLAlias"));
                #elseif ($shortType == "class java.lang.Double" || $shortType == "double")
            instance.set${methodSuffix}(resultSet.getDouble("$SQLAlias"));
                #elseif ($shortType == "class java.lang.Boolean" || $shortType == "boolean")
            instance.set${methodSuffix}(resultSet.getBoolean("$SQLAlias"));
                #else
                    #if (${isForeignKey})
                        #if (${lazyFetch})
            // Vytvorenie proxy na oneskorené načítanie
            long foreignKeyId = resultSet.getLong("$SQLAlias");
            instance.set${methodSuffix}((${methodSuffix}) LazyProxyHandler.createProxy(
                ${methodSuffix}.class,
                ${column.TargetClass}.class,
                foreignKeyId,
                daoPersistenceManager
            ));
                        #else
            // Bežné načítanie cudzieho kľúča
            Optional<?> optionalValue = daoPersistenceManager.get(field.getType(), resultSet.getLong("$SQLAlias"));
            instance.set${methodSuffix}((${methodSuffix}) optionalValue.orElse(null));
                        #end
                    #else
                        System.out.println(resultSet.getObject("$SQLAlias"));
            instance.set${methodSuffix}((${methodSuffix}) resultSet.getObject("$SQLAlias"));
                    #end
                #end
            #end

            return instance;
        } catch (SQLException e) {
            throw new PersistenceException("Error creating $entity.Name from database result", e);
        }
    }

    private boolean checkForeignKeysExists($entity.Name entity) {
        #foreach ($fieldNameEntity in $entity.ForeignKeyList)
        // TODO: this must use note entity but use field
        Object PK = null;
        if (Proxy.isProxyClass(entity.getClass())) {
            InvocationHandler handler = Proxy.getInvocationHandler(entity);

            if (handler instanceof LazyProxyHandler lazyHandler) {
                System.out.println("proxy is LazyProxyHandler");
                PK = lazyHandler.getId();
            }
        }

        if (PK == null) {
            PK = (entity.${fieldNameEntity.FieldGetterName}() != null && entity.${fieldNameEntity.FieldGetterName}() instanceof ${fieldNameEntity.TargetClass}) ? ((${fieldNameEntity.TargetClass}) entity.${fieldNameEntity.FieldGetterName}()).${fieldNameEntity.PKGetterName}() : null;
        }

        if (PK != null) {
            if (!PKExist("${fieldNameEntity.ReferencedTable}", "${fieldNameEntity.SQLFieldName}", PK)) {
                return false;
            }
        } else {
            return false;
        }
        #end
        return true;
    }

    private boolean PKExist(String databaseName, String databaseColumn, Object PK) {
        try (PreparedStatement preparedStatement = connection.prepareStatement("SELECT 1 FROM \"" + databaseName + "\" WHERE \"" + databaseColumn + "\" = ?")) {
            preparedStatement.setObject(1, PK);
            try (ResultSet resultSet = preparedStatement.executeQuery()) {
                return resultSet.next();
            }
        } catch (SQLException e) {
            return false;
        }
    }
